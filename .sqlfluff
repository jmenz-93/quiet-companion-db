[sqlfluff]
dialect = postgres
templater = raw
exclude_rules = L031,L036,L044,L046,L051,L052,L053,L054,L055,L056,L057,L058,L059,L060,L061,L062,L063,L064,L065,L066,L067,L068

[sqlfluff:rules]
tab_space_size = 4
max_line_length = 120

[sqlfluff:rules:L010]
capitalisation_policy = upper

[sqlfluff:rules:L014]
extended_capitalisation_policy = upper

[sqlfluff:rules:L030]
capitalisation_policy = upper
